# Root-level sensitive files
.env
.env.*
*.local
*credentials*.env

# Firebase / GCP secrets and diagnostics
.firebase/
firebase-debug.log
firebase-debug.*.log
*serviceAccount*.json
*.private-key.json
firebase_config/*.json

# Mobile signing material
*.jks
*.keystore
*.p12
*.p8
*.mobileprovision

# Firebase app config files (kept local; platform-specific copies may exist)
**/google-services.json
**/GoogleService-Info.plist
*.DS_Store
